# ═══════════════════════════════════════════════════════════════════════════
# Senior Engineer Advisor — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════

# ── Agent Model (cheap / fast) ───────────────────────────────────────────────
# Used for: complexity assessment, implementation, wiki search
# Recommended: DeepSeek V3 (best cost/quality ratio for coding tasks)

# Option A: OpenRouter (covers both agent and advisor with one key)
AGENT_API_BASE=https://openrouter.ai/api/v1
AGENT_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
AGENT_MODEL=deepseek/deepseek-chat-v3-5

# Option B: Kilo Pass
# AGENT_API_BASE=https://api.kilocode.ai/v1
# AGENT_API_KEY=kilo-xxxxxxxxxxxxxxxxxxxx
# AGENT_MODEL=deepseek/deepseek-v3

# Option C: Together.ai
# AGENT_API_BASE=https://api.together.xyz/v1
# AGENT_API_KEY=xxxxxxxxxxxxxxxxxxxx
# AGENT_MODEL=Qwen/Qwen3-235B-A22B

# Option D: Local (Ollama — OpenAI-compatible)
# AGENT_API_BASE=http://localhost:11434/v1
# AGENT_API_KEY=ollama
# AGENT_MODEL=qwen2.5-coder:32b

# ── Advisor Model (high-capability) ─────────────────────────────────────────
# Used for: architectural guidance on complex tasks only
# Recommended: Claude Opus (via OpenRouter or Anthropic direct)

# Option A: OpenRouter (same key as above if using OpenRouter for agent)
ADVISOR_API_BASE=https://openrouter.ai/api/v1
ADVISOR_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
ADVISOR_MODEL=anthropic/claude-opus-4.6

# Option B: Kilo Pass
# ADVISOR_API_BASE=https://api.kilocode.ai/v1
# ADVISOR_API_KEY=kilo-xxxxxxxxxxxxxxxxxxxx
# ADVISOR_MODEL=anthropic/claude-opus-4.6

# Option C: Anthropic Direct
# ADVISOR_API_BASE=https://api.anthropic.com/v1
# ADVISOR_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# ADVISOR_MODEL=claude-opus-4-5-20251001

# ── Knowledge Base ───────────────────────────────────────────────────────────
# Where to store/search learned patterns (Karpathy LLM Wiki pattern)

# Plain markdown directory (no Obsidian required)
WIKI_DIR=${HOME}/.advisor/wiki

# Obsidian vault (if you use Obsidian — higher-quality knowledge management)
# OBSIDIAN_VAULT=${HOME}/Documents/ObsidianVault

# Wiki similarity threshold (0.0–1.0). Lower = more aggressive caching.
WIKI_THRESHOLD=0.25

# ── Behavior ─────────────────────────────────────────────────────────────────
# Complexity score >= this threshold triggers advisor consultation
COMPLEXITY_THRESHOLD=0.5

# Advisor response depth (1=concise ... 5=comprehensive)
ADVICE_DEPTH=3
