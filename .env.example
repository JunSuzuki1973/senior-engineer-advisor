# Senior Engineer Advisor - Environment Variables
# Copy to .env and customize for your setup

# ============================================
# API KEYS (Required)
# ============================================

# OpenCode Go API Key (for implementation agent - primary)
export OPENCODE_API_KEY="REMOVED_OPENCODE_API_KEY"

# z.ai API Key (fallback for implementation agent)
export ZAI_API_KEY="REMOVED_ZAI_API_KEY"

# Kilo Pass API Key (for advisor)
export KILO_PASS_API_KEY="REMOVED_KILO_PASS_JWT"

# ============================================
# PATHS (Optional - defaults shown)
# ============================================

# LLM Wiki directory
export WIKI_DIR="$HOME/openclaw-wiki"

# Agency Agents directory
export AA_DIR="$HOME/agency-agents"

# ============================================
# ADVISOR SETTINGS (Optional)
# ============================================

# Advice Depth Level (1-5)
# 1 = Simple: High-level only, brief responses
# 2 = General: Key points, main decisions
# 3 = Standard: Architecture + decisions + pitfalls + best practices (default)
# 4 = Detailed: Comprehensive with specific implementation suggestions
# 5 = Comprehensive: Exhaustive analysis, alternatives, code patterns
export ADVICE_DEPTH="3"

# ============================================
# MODEL OVERRIDES (Optional)
# ============================================

# Default implementation model (OpenCode Go)
# export DEFAULT_MODEL="opencode-go/glm-5"

# Fallback model (z.ai) - used if OpenCode Go fails
# export FALLBACK_MODEL="zai/glm-5"

# Advisor model (Kilo Pass)
# export ADVISOR_MODEL="kilo/anthropic/claude-opus-4-6"
